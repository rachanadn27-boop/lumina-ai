{
  "name": "lumina",
  "version": "1.0.0",
  "description": "Privacy-first local AI writing assistant",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
